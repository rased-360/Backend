## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# DotNet things
project.lock.json
project.fragment.lock.json
artifacts/

# Sensitive configs
appsettings.json
appsettings.*.json

# Others
node_modules/
wwwroot/lib/
.env
*.db
*.sqlite
*.pdb
.idea/
*.publish.xml
